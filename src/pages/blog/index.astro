---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Topics row — grows automatically as posts gain tags.
const topics = [...new Set(posts.flatMap((p) => p.data.tags ?? []))];
const count = posts.length;

// Pagination is a placeholder until the archive is large enough to need it.
const PAGE_SIZE = 15;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1000px;
			}

			/* Two-column layout: left rail for the title, right column for posts */
			.blog-layout {
				display: grid;
				grid-template-columns: 200px minmax(0, 1fr);
				gap: 2.5rem;
				align-items: start;
			}

			/* Left rail — the "Blog" title hangs to the left of the post column */
			.blog-head h1 {
				margin: 0 0 0.5rem 0;
				font-size: 2.1rem;
				line-height: 1.1;
			}
			.blog-head .subtitle {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
				line-height: 1.45;
			}

			.blog-content {
				min-width: 0;
			}

			/* Topics row (placeholder that fills in from tags) */
			.topics {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin: 0 0 2rem 0;
				padding-bottom: 1.25rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.chip {
				font-size: 0.85rem;
				line-height: 1;
				padding: 0.4em 0.7em;
				border-radius: 999px;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
			}

			/* Post list — single column of horizontal cards */
			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-card {
				padding: 1.75rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-card:first-child {
				padding-top: 0;
			}
			.card-link {
				display: flex;
				gap: 1.5rem;
				align-items: flex-start;
				text-decoration: none;
				color: inherit;
			}
			.thumb {
				flex: 0 0 240px;
			}
			.thumb :global(img) {
				width: 100%;
				height: auto;
				border-radius: 10px;
				transition: box-shadow 0.2s ease;
			}
			.card-body {
				flex: 1 1 auto;
				min-width: 0;
			}
			.card-body .title {
				margin: 0 0 0.35rem 0;
				font-size: 1.6rem;
				line-height: 1.15;
				color: rgb(var(--black));
				transition: color 0.2s ease;
			}
			.meta {
				margin: 0 0 0.6rem 0;
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}
			.excerpt {
				margin: 0;
				color: rgb(var(--gray-dark));
				font-size: 1rem;
				line-height: 1.55;
			}
			.card-link:hover .title {
				color: var(--accent);
			}
			.card-link:hover .thumb :global(img) {
				box-shadow: var(--box-shadow);
			}

			/* Pagination placeholder */
			.pager {
				display: flex;
				justify-content: space-between;
				margin-top: 2rem;
				color: rgb(var(--gray));
			}

			/* Follow / subscribe placeholder */
			.subscribe {
				margin-top: 3rem;
				padding: 1.75rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				text-align: center;
			}
			.subscribe h3 {
				margin: 0 0 0.4rem 0;
			}
			.subscribe p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 1rem;
			}

			/* Collapse to a single column on narrow screens */
			@media (max-width: 820px) {
				main {
					width: 100%;
				}
				.blog-layout {
					grid-template-columns: 1fr;
					gap: 1rem;
				}
				.blog-head {
					margin-bottom: 0.5rem;
				}
			}
			@media (max-width: 720px) {
				.card-link {
					flex-direction: column;
					gap: 0.75rem;
				}
				.thumb {
					flex-basis: auto;
					width: 100%;
				}
				.card-body .title {
					font-size: 1.4rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="blog-layout">
				<header class="blog-head">
					<h1>Blog</h1>
					<p class="subtitle">
						{count} {count === 1 ? 'essay' : 'essays'} on OT security, AI, and critical infrastructure.
					</p>
				</header>

				<div class="blog-content">
					{
						topics.length > 0 && (
							<nav class="topics" aria-label="Topics">
								{topics.map((t) => (
									<span class="chip">#{t}</span>
								))}
							</nav>
						)
					}

					<ul class="post-list">
						{
							posts.map((post) => (
								<li class="post-card">
									<a class="card-link" href={`/blog/${post.id}/`}>
										{post.data.heroImage && (
											<div class="thumb">
												<Image width={520} height={349} src={post.data.heroImage} alt="" />
											</div>
										)}
										<div class="card-body">
											<h2 class="title">{post.data.title}</h2>
											<p class="meta">
												<FormattedDate date={post.data.pubDate} />
												{post.data.tags?.length ? (
													<span> · {post.data.tags.map((t) => `#${t}`).join(' ')}</span>
												) : null}
											</p>
											{post.data.description && <p class="excerpt">{post.data.description}</p>}
										</div>
									</a>
								</li>
							))
						}
					</ul>

					{
						count > PAGE_SIZE && (
							<nav class="pager" aria-label="Pagination">
								<span>← Previous</span>
								<span>Next →</span>
							</nav>
						)
					}

					<aside class="subscribe">
						<h3>Follow along</h3>
						<p>New writing on OT security, AI, and the systems society runs on. A newsletter is in the works.</p>
					</aside>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
