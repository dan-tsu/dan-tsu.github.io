---
import { Image } from 'astro:assets';
import avatar from '../assets/avatar.png';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<div class="brand">
			<h2>
				<a href="/">
					<Image src={avatar} alt="Daniel Suchý" width={80} height={80} class="avatar" />
					<span>{SITE_TITLE}</span>
				</a>
			</h2>
			<span class="divider" aria-hidden="true"></span>
			<a
				class="social"
				href="https://www.linkedin.com/in/daniel-s1228/"
				target="_blank"
				rel="me noopener"
				aria-label="Daniel Suchý on LinkedIn"
			>
				<svg viewBox="0 0 16 16" width="22" height="22" aria-hidden="true" fill="currentColor">
					<path
						d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"
					></path>
				</svg>
			</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/daemon">Daemon</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
	}
	.avatar {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		object-fit: cover;
	}
	/* Brand cluster: name · divider · LinkedIn icon */
	.brand {
		display: flex;
		align-items: center;
		gap: 1.1rem;
	}
	.divider {
		flex: 0 0 auto;
		width: 1px;
		height: 26px;
		background: rgb(var(--gray-light));
	}
	.social {
		display: inline-flex;
		align-items: center;
		padding: 0.5em;
		color: rgb(var(--gray));
		border-bottom: none;
		transition: color 0.2s ease;
	}
	.social:hover {
		color: var(--accent);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.internal-links {
		display: flex;
		align-items: center;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		white-space: nowrap;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
</style>
